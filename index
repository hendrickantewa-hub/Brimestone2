<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Brimstone — Health | Skin | Aesthetics</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
:root{
  --ink:#0D0D0D;--char:#1C1C1C;--mid:#5A5A5A;--soft:#909090;
  --border:rgba(0,0,0,0.09);--bg:#FAFAFA;--white:#FFFFFF;--off:#F4F3F1;
  --green:#2D6A55;--green-l:#3D8A6E;--green-p:#EAF3EF;
  --acc:#B8860B;--acc-p:#F5EDD8;
  --sh-sm:0 2px 16px rgba(0,0,0,0.07);
  --sh-md:0 8px 40px rgba(0,0,0,0.1);
  --sh-lg:0 20px 60px rgba(0,0,0,0.14);
}
body{font-family:"DM Sans",sans-serif;background:var(--bg);color:var(--char);overflow-x:hidden}

/* ── NAV ── */
#nav{
  position:fixed;top:0;left:0;right:0;z-index:300;height:68px;
  display:flex;align-items:center;justify-content:space-between;padding:0 5%;
  background:rgba(250,250,250,0.97);backdrop-filter:blur(18px);
  border-bottom:1px solid var(--border);transition:box-shadow .3s;
}
#nav.raised{box-shadow:0 4px 24px rgba(0,0,0,0.08)}
.nav-logo{display:flex;align-items:center;cursor:pointer}
.nav-logo-img{height:44px;width:auto;object-fit:contain;cursor:pointer}
.nav-tabs{display:flex;align-items:center;gap:2px}
.nav-tab{
  background:none;border:none;cursor:pointer;font-family:"DM Sans",sans-serif;
  font-size:.79rem;font-weight:500;letter-spacing:.07em;text-transform:uppercase;
  color:var(--soft);padding:8px 15px;border-radius:50px;transition:all .2s;
}
.nav-tab:hover{color:var(--ink);background:var(--off)}
.nav-tab.active{color:var(--green);background:var(--green-p)}
.nav-cta{
  background:var(--ink);color:white;border:none;cursor:pointer;
  font-family:"DM Sans",sans-serif;font-size:.79rem;font-weight:500;
  letter-spacing:.06em;padding:10px 22px;border-radius:50px;
  transition:all .2s;display:flex;align-items:center;gap:7px;
}
.nav-cta:hover{background:var(--char);transform:translateY(-1px);box-shadow:0 6px 20px rgba(0,0,0,.22)}
.hamburger{display:none;background:none;border:none;cursor:pointer;padding:5px;flex-direction:column;gap:5px}
.hamburger span{display:block;width:20px;height:2px;background:var(--ink);border-radius:2px}
.mob-menu{
  display:none;position:fixed;inset:0;top:68px;z-index:200;
  background:var(--white);flex-direction:column;align-items:center;justify-content:center;gap:6px;
}
.mob-menu.open{display:flex}
.mob-tab{
  background:none;border:none;cursor:pointer;font-family:"DM Sans",sans-serif;
  font-size:1rem;font-weight:400;color:var(--mid);padding:14px 32px;
  border-radius:12px;width:200px;text-align:center;transition:all .2s;
}
.mob-tab.active{color:var(--green);background:var(--green-p)}

/* ── PAGES ── */
.page{display:none;animation:pageIn .3s ease}
.page.active{display:block}
@keyframes pageIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* ── BUTTONS ── */
.btn-dark{background:var(--ink);color:white;padding:13px 28px;border-radius:50px;text-decoration:none;font-size:.875rem;font-weight:500;letter-spacing:.03em;display:inline-flex;align-items:center;gap:7px;transition:all .25s;border:none;cursor:pointer;font-family:"DM Sans",sans-serif;}
.btn-dark:hover{background:var(--char);transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.2)}
.btn-green{background:var(--green);color:white;padding:13px 28px;border-radius:50px;text-decoration:none;font-size:.875rem;font-weight:500;letter-spacing:.03em;display:inline-flex;align-items:center;gap:7px;transition:all .25s;border:none;cursor:pointer;font-family:"DM Sans",sans-serif;}
.btn-green:hover{background:var(--green-l);transform:translateY(-2px);box-shadow:0 8px 24px rgba(45,106,85,.3)}
.btn-outline{background:transparent;color:var(--ink);padding:12px 26px;border-radius:50px;text-decoration:none;font-size:.875rem;font-weight:400;border:1.5px solid var(--border);display:inline-flex;align-items:center;gap:7px;transition:all .25s;cursor:pointer;font-family:"DM Sans",sans-serif;}
.btn-outline:hover{border-color:var(--ink);transform:translateY(-2px)}
.btn-white{background:white;color:var(--ink);padding:13px 28px;border-radius:50px;text-decoration:none;font-size:.875rem;font-weight:600;display:inline-flex;align-items:center;gap:7px;transition:all .25s;white-space:nowrap;box-shadow:0 4px 16px rgba(0,0,0,.1);}
.btn-white:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.18)}

/* ── SHARED ── */
.sec-label{font-size:.68rem;letter-spacing:.15em;text-transform:uppercase;color:var(--green);font-weight:600;margin-bottom:8px;display:block}
.sec-title{font-family:"Cormorant Garamond",serif;font-size:clamp(1.9rem,3.8vw,3rem);font-weight:400;color:var(--ink);line-height:1.15;margin-bottom:12px}
.sec-title em{font-style:italic;color:var(--green)}
.page-hero{padding:110px 6% 56px;background:var(--off);text-align:center;position:relative}
.page-hero::after{content:'';position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:48px;height:3px;background:var(--green);border-radius:2px}
.page-hero-logo{height:50px;object-fit:contain;margin:0 auto 22px;display:block}
.page-hero h1{font-family:"Cormorant Garamond",serif;font-size:clamp(2rem,4vw,2.9rem);font-weight:400;color:var(--ink);margin-bottom:12px}
.page-hero h1 em{font-style:italic;color:var(--green)}
.page-hero p{font-size:.93rem;color:var(--mid);max-width:480px;margin:0 auto;line-height:1.75;font-weight:300}

/* ═══════ HOME ═══════ */
.home-hero{
  min-height:100vh;background:var(--off);
  display:grid;grid-template-columns:1fr 1fr;
  align-items:center;gap:52px;padding:100px 6% 80px;
  position:relative;overflow:hidden;
}
.hero-bg-mesh{
  position:absolute;inset:0;pointer-events:none;
  background:radial-gradient(ellipse 60% 50% at 70% 50%,rgba(45,106,85,.05) 0%,transparent 65%),
             radial-gradient(ellipse 40% 40% at 10% 80%,rgba(184,134,11,.05) 0%,transparent 60%);
}
.hero-content{position:relative;z-index:2}
.hero-eyebrow{
  display:inline-flex;align-items:center;gap:8px;
  background:white;border:1px solid var(--border);padding:7px 16px;border-radius:50px;
  font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--green);
  font-weight:500;margin-bottom:28px;box-shadow:var(--sh-sm);
  animation:fadeUp .7s ease both;
}
.hero-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(1.4)}}
.hero-h1{
  font-family:"Cormorant Garamond",serif;
  font-size:clamp(2.6rem,5vw,4.2rem);font-weight:300;line-height:1.08;
  color:var(--ink);margin-bottom:20px;animation:fadeUp .7s .1s ease both;
}
.hero-h1 em{font-style:italic;color:var(--green)}
.hero-p{font-size:.97rem;color:var(--mid);line-height:1.8;font-weight:300;max-width:440px;margin-bottom:36px;animation:fadeUp .7s .2s ease both}
.hero-btns{display:flex;flex-wrap:wrap;gap:12px;animation:fadeUp .7s .3s ease both}
.hero-visual{position:relative;z-index:2;animation:fadeUp .8s .15s ease both}
.hero-img-box{
  position:relative;width:100%;max-width:520px;
}
.hero-main-img{
  width:100%;height:360px;object-fit:cover;object-position:center bottom;
  border-radius:20px;box-shadow:var(--sh-lg);display:block;
}
/* Stats now sit BELOW the image, not overlapping */
.hero-stats-row{
  display:flex;gap:14px;margin-top:16px;
}
.hero-stat-card{
  flex:1;background:white;border-radius:14px;padding:14px 18px;
  box-shadow:var(--sh-sm);border:1px solid var(--border);
  text-align:center;
}
.stat-num{font-family:"Cormorant Garamond",serif;font-size:1.6rem;font-weight:500;color:var(--green);line-height:1}
.stat-lbl{font-size:.65rem;color:var(--soft);letter-spacing:.04em;margin-top:3px}

/* Trust bar */
.trust-bar{
  background:var(--ink);padding:20px 6%;
  display:flex;align-items:center;justify-content:center;gap:0;flex-wrap:wrap;
}
.trust-item{
  display:flex;align-items:center;gap:8px;color:rgba(255,255,255,.6);
  font-size:.78rem;letter-spacing:.04em;padding:7px 20px;
  border-right:1px solid rgba(255,255,255,.1);
}
.trust-item:last-child{border-right:none}
.trust-item svg{color:#B8A878;flex-shrink:0}

/* Home feature cards */
.home-features{padding:80px 6%;background:var(--white)}
.feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;max-width:1100px;margin:48px auto 0}
.feat-card{background:var(--bg);border-radius:18px;overflow:hidden;border:1px solid var(--border);box-shadow:var(--sh-sm);cursor:pointer;transition:all .3s;}
.feat-card:hover{transform:translateY(-5px);box-shadow:var(--sh-md);border-color:var(--green)}
.feat-img{width:100%;height:195px;object-fit:cover;display:block;transition:transform .5s}
.feat-card:hover .feat-img{transform:scale(1.04)}
.feat-body{padding:22px 20px}
.feat-cat{font-size:.64rem;letter-spacing:.14em;text-transform:uppercase;color:var(--green);font-weight:600;margin-bottom:5px}
.feat-card h3{font-family:"Cormorant Garamond",serif;font-size:1.3rem;font-weight:500;color:var(--ink);margin-bottom:7px;line-height:1.2}
.feat-card p{font-size:.81rem;color:var(--mid);line-height:1.7}
.feat-arrow{display:inline-flex;align-items:center;gap:5px;margin-top:10px;color:var(--green);font-size:.79rem;font-weight:500;transition:gap .2s}
.feat-arrow:hover{gap:9px}

/* BA teaser */
.ba-section{padding:0 6% 80px;background:var(--white)}
.ba-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;max-width:800px;margin:32px auto 0}
.ba-wrap{position:relative;border-radius:14px;overflow:hidden;box-shadow:var(--sh-md)}
.ba-img{width:100%;height:260px;object-fit:cover;object-position:center top;display:block}
.ba-tag{
  position:absolute;bottom:10px;left:10px;
  padding:4px 12px;border-radius:50px;font-size:.64rem;
  letter-spacing:.1em;text-transform:uppercase;font-weight:600;color:white;
}
.tag-b{background:rgba(0,0,0,.68)}
.tag-a{background:rgba(45,106,85,.85)}

/* ═══════ SERVICES ═══════ */
.svc-section{padding:64px 6% 80px;background:var(--white)}
.svc-cat{max-width:1100px;margin:0 auto 60px}
.svc-cat-hdr{display:flex;align-items:center;gap:16px;margin-bottom:22px;padding-bottom:16px;border-bottom:1px solid var(--border)}
.sci{width:50px;height:50px;border-radius:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.sci.g{background:var(--green-p)} .sci.g svg{color:var(--green)}
.sci.a{background:var(--acc-p)} .sci.a svg{color:var(--acc)}
.sci.d{background:#E8E8E8} .sci.d svg{color:var(--char)}
.svc-cat-hdr h2{font-family:"Cormorant Garamond",serif;font-size:1.8rem;font-weight:500;color:var(--ink)}
.svc-cat-hdr p{font-size:.84rem;color:var(--soft);margin-top:2px}
.svc-banner{width:100%;height:195px;object-fit:cover;border-radius:14px;margin-bottom:20px;display:block}
.svc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:13px}
.svc-item{background:var(--bg);border-radius:11px;padding:16px 15px;border:1px solid var(--border);transition:all .25s;display:flex;align-items:flex-start;gap:9px;}
.svc-item:hover{border-color:var(--green);box-shadow:0 5px 20px rgba(45,106,85,.1);transform:translateY(-2px)}
.svc-item.ai:hover{border-color:var(--acc);box-shadow:0 5px 20px rgba(184,134,11,.1)}
.sd{width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:6px}
.sd.g{background:var(--green)} .sd.a{background:var(--acc)} .sd.d{background:var(--char)}
.svc-item h4{font-size:.86rem;font-weight:500;color:var(--ink);line-height:1.3}
.svc-cta-bar{max-width:1100px;margin:0 auto;background:var(--ink);border-radius:18px;padding:40px 48px;display:flex;align-items:center;justify-content:space-between;gap:22px;flex-wrap:wrap;}
.svc-cta-bar h3{font-family:"Cormorant Garamond",serif;font-size:1.55rem;font-weight:400;color:white}
.svc-cta-bar p{color:rgba(255,255,255,.5);font-size:.84rem;margin-top:5px}

/* ═══════ RESULTS ═══════ */
.results-section{padding:64px 6% 80px;background:var(--white)}
.result-block{max-width:1100px;margin:0 auto 56px}
.result-block-title{
  font-family:"Cormorant Garamond",serif;font-size:1.6rem;font-weight:400;color:var(--ink);
  margin-bottom:8px;padding-bottom:14px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:12px;
}
.result-block-title span{font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;color:var(--green);font-weight:600;background:var(--green-p);padding:4px 12px;border-radius:50px}
.ba-pair{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px}
.ba-pair-4{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
.ba-img-card{position:relative;border-radius:14px;overflow:hidden;box-shadow:var(--sh-md)}
.ba-img-card img{width:100%;height:280px;object-fit:cover;object-position:center top;display:block;transition:transform .4s}
.ba-img-card:hover img{transform:scale(1.02)}
.ba-lbl{position:absolute;top:10px;left:10px;padding:4px 12px;border-radius:50px;font-size:.63rem;letter-spacing:.1em;text-transform:uppercase;font-weight:700;color:white;}
.lbl-before{background:rgba(0,0,0,.7)} .lbl-after{background:rgba(45,106,85,.82)}
.result-desc{font-size:.85rem;color:var(--mid);line-height:1.75;margin-top:14px;padding:14px 18px;background:var(--bg);border-radius:10px;border-left:3px solid var(--green)}
.disclaimer{max-width:1100px;margin:32px auto 0;text-align:center;font-size:.77rem;color:var(--soft);line-height:1.7;padding:14px 20px;background:var(--off);border-radius:10px;border:1px solid var(--border)}

/* ═══════ TEAM ═══════ */
.team-section{padding:64px 6% 80px;background:var(--white)}
.team-layout{display:grid;grid-template-columns:1fr 1.2fr;gap:68px;align-items:start;max-width:1000px;margin:0 auto}
.portrait-bg{position:absolute;width:290px;height:370px;background:var(--green-p);border-radius:20px;top:20px;left:20px}
.team-portrait-wrap{position:relative}
.team-portrait{position:relative;z-index:1;width:272px;height:352px;object-fit:cover;object-position:center top;border-radius:16px;box-shadow:var(--sh-lg);display:block;}
.team-badge{position:absolute;z-index:2;bottom:-14px;right:10px;background:white;border-radius:12px;padding:13px 18px;box-shadow:0 8px 28px rgba(0,0,0,.1);border:1px solid var(--border);}
.badge-icon{font-size:1.1rem;display:block;text-align:center;margin-bottom:3px}
.badge-txt{font-size:.63rem;color:var(--soft);text-transform:uppercase;letter-spacing:.06em;text-align:center}
.team-info{}
.team-role{font-size:.7rem;letter-spacing:.14em;text-transform:uppercase;color:var(--green);font-weight:600;margin-bottom:6px}
.team-name{font-family:"Cormorant Garamond",serif;font-size:2.1rem;font-weight:500;color:var(--ink);line-height:1.1;margin-bottom:5px}
.team-title{font-size:.84rem;color:var(--green);font-weight:400;letter-spacing:.04em;margin-bottom:20px}
.team-bio{font-size:.91rem;color:var(--mid);line-height:1.85;margin-bottom:13px;font-weight:300}
.quals-heading{font-size:.66rem;letter-spacing:.12em;text-transform:uppercase;color:var(--soft);font-weight:600;margin-bottom:11px;display:flex;align-items:center;gap:10px}
.quals-heading::after{content:'';flex:1;height:1px;background:var(--border)}
.quals-list{display:flex;flex-direction:column;gap:8px;margin-bottom:24px}
.qual-item{display:flex;align-items:center;gap:10px;padding:10px 13px;background:var(--bg);border-radius:9px;border:1px solid var(--border);transition:border-color .2s}
.qual-item:hover{border-color:var(--green)}
.qual-dot{width:6px;height:6px;border-radius:50%;background:var(--green);flex-shrink:0}
.qual-item span{font-size:.82rem;color:var(--mid)}

/* ═══════ CONTACT ═══════ */
.contact-section{padding:64px 6% 80px;background:var(--white)}
.branch-tabs{display:flex;gap:10px;max-width:1100px;margin:0 auto 36px;flex-wrap:wrap}
.branch-tab{
  background:var(--bg);border:1.5px solid var(--border);border-radius:12px;
  padding:16px 24px;cursor:pointer;transition:all .25s;flex:1;min-width:200px;
  font-family:"DM Sans",sans-serif;text-align:left;
}
.branch-tab:hover{border-color:var(--green)}
.branch-tab.active{border-color:var(--green);background:var(--green-p)}
.bt-name{font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:var(--green);font-weight:600;margin-bottom:3px}
.bt-loc{font-size:.92rem;font-weight:500;color:var(--ink)}
.bt-sub{font-size:.77rem;color:var(--soft);margin-top:2px}
.branch-panel{display:none}
.branch-panel.active{display:grid;grid-template-columns:1.1fr 1fr;gap:48px;max-width:1100px;margin:0 auto;align-items:start}
.cc-wrap{display:flex;flex-direction:column;gap:12px}
.cc{display:flex;align-items:flex-start;gap:13px;background:var(--bg);padding:15px 17px;border-radius:12px;border:1px solid var(--border);transition:border-color .2s}
.cc:hover{border-color:var(--green)}
.cc-icon{width:36px;height:36px;border-radius:10px;background:var(--green-p);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.cc-icon svg{color:var(--green)}
.cc-lbl{font-size:.63rem;text-transform:uppercase;letter-spacing:.08em;color:var(--soft);margin-bottom:2px}
.cc-val{font-size:.875rem;color:var(--ink);font-weight:500;text-decoration:none;display:block}
.cc-val:hover{color:var(--green)}
.cc-val.sm{font-size:.78rem;font-weight:400;color:var(--mid)}
.hours-card{background:var(--bg);border-radius:16px;padding:28px 26px;border:1px solid var(--border);box-shadow:var(--sh-sm)}
.hours-card h3{font-family:"Cormorant Garamond",serif;font-size:1.25rem;font-weight:500;color:var(--ink);margin-bottom:16px;padding-bottom:13px;border-bottom:1px solid var(--border)}
.hr-row{display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid rgba(0,0,0,.04);font-size:.84rem}
.hr-row:last-of-type{border-bottom:none}
.hr-day{color:var(--mid)} .hr-time{color:var(--ink);font-weight:500} .hr-c{color:var(--soft);font-style:italic}
.hours-note{margin-top:14px;padding:12px 13px;background:var(--green-p);border-radius:9px;font-size:.76rem;color:var(--green);line-height:1.6;display:flex;gap:8px}
.book-btns{margin-top:18px;display:flex;flex-direction:column;gap:9px}
.book-btns .btn-green,.book-btns .btn-outline{justify-content:center;width:100%}

/* ── FOOTER ── */
footer{background:var(--char);padding:44px 6% 22px}
.ft{display:flex;justify-content:space-between;align-items:flex-start;gap:28px;flex-wrap:wrap;margin-bottom:32px}
.f-brand-logo{height:40px;object-fit:contain;margin-bottom:10px;display:block}
.f-tagline{font-size:.77rem;color:rgba(255,255,255,.35);max-width:180px;line-height:1.7}
.f-col h5{font-size:.63rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:11px}
.f-col ul{list-style:none;display:flex;flex-direction:column;gap:8px}
.f-col a{color:rgba(255,255,255,.5);text-decoration:none;font-size:.81rem;transition:color .2s}
.f-col a:hover{color:white}
.ft-bottom{border-top:1px solid rgba(255,255,255,.07);padding-top:16px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px}
.ft-copy{font-size:.72rem;color:rgba(255,255,255,.25)}

@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

/* MOBILE */
@media(max-width:860px){
  .nav-tabs{display:none} .hamburger{display:flex}
  .home-hero{grid-template-columns:1fr;padding:90px 5% 60px;text-align:center}
  .hero-visual{order:-1}
  .hero-main-img{height:220px}
  .hero-stats-row{justify-content:center}
  .hero-btns{justify-content:center}
  .feat-grid{grid-template-columns:1fr;max-width:420px;margin-left:auto;margin-right:auto}
  .ba-grid{grid-template-columns:1fr}
  .ba-pair{grid-template-columns:1fr}
  .ba-pair-4{grid-template-columns:1fr}
  .team-layout{grid-template-columns:1fr;gap:36px}
  .branch-panel.active{grid-template-columns:1fr}
